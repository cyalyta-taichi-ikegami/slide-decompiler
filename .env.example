# このファイルを .env にコピーして値を設定してください
# .env 自体は .gitignore に含まれているため Git に追跡されません

# [必須] Google Cloud プロジェクト ID
GCP_PROJECT_ID=your-project-id

# [任意] Vertex AI リージョン（デフォルト: us-central1）
GCP_LOCATION=us-central1

# [任意] 使用モデル名
GEMINI_MODEL=gemini-2.5-flash
IMAGEN_MODEL=imagen-3.0-capability-001

# [任意] Cloud Storage バケット名（GCS 経由で入出力する場合）
GCS_BUCKET=your-bucket-name

# [任意] 同時処理スライド数（Vertex AI の TPM クォータに合わせて調整）
MAX_CONCURRENT_SLIDES=3

# [任意] 入出力ファイルパス（--input / --output の代替）
# INPUT_PATH=/path/to/input.pptx
# OUTPUT_PATH=/path/to/output.pptx
